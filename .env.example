# StreamChat Overlay — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────────
# Render.com sets PORT automatically. Leave blank for local (defaults to 8000)
PORT=8000

# ── YouTube Live Chat ──────────────────────────────────────────────────────────
# The YouTube video ID of your live stream (from the URL: ?v=VIDEO_ID)
# Example: https://www.youtube.com/watch?v=dQw4w9WgXcQ → dQw4w9WgXcQ
YOUTUBE_VIDEO_ID=

# ── Twitch IRC ─────────────────────────────────────────────────────────────────
TWITCH_CHANNEL=
TWITCH_OAUTH_TOKEN=
TWITCH_BOT_NICK=justinfan12345

# ── Kick ───────────────────────────────────────────────────────────────────────
KICK_CHANNEL=

# ── Rumble ─────────────────────────────────────────────────────────────────────
RUMBLE_STREAM_URL=

# ── Facebook Live ──────────────────────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_VIDEO_ID=

# ── Instagram Live ─────────────────────────────────────────────────────────────
# Master switch — must be "true" for any Instagram functionality
INSTAGRAM_ENABLED=false

# Full URL to the Instagram Live page
# Example: https://www.instagram.com/therock/live/
IG_LIVE_URL=

# Option A — Session cookie (RECOMMENDED; more stable than u/p login)
# How to get it:
#   1. Log into Instagram in your browser
#   2. Open DevTools → Application → Cookies → https://www.instagram.com
#   3. Copy the value of the "sessionid" cookie
#   Paste the raw value OR a JSON array of Playwright cookie objects
IG_SESSION_COOKIE=

# Option B — Username / password (fallback; may trigger 2FA challenges)
IG_USERNAME=
IG_PASSWORD=

# Set to "true" to force demo/mock mode even when real credentials are set
# Useful for testing the overlay UI without a live stream running
INSTAGRAM_MOCK_MODE=false
